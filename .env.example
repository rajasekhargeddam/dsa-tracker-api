MONGO_URI=mongodb://localhost:27017/dsa-tracker
PORT=5000
# Comma-separated list of allowed frontend origins (omit to allow all in dev)
CORS_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# Shared code required to sign up
INVITE_CODE=replace-with-a-private-code
